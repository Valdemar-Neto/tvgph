generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(uuid()) @db.Uuid
  name              String
  email             String       @unique
  password          String
  role              Role         @default(MEMBER)
  avatarUrl         String?
  bio               String?
  active            Boolean      @default(false)
  createdAt         DateTime     @default(now())
  resetToken        String?
  resetTokenExpires DateTime?
  lastResetRequestAt DateTime?
  attendance        Attendance[]
  comments          Comment[]
  likes             Like[]
  meetings          Meeting[]    @relation("MeetingCreator")
  reports           Report[]
  userAreas         UserArea[]
}

model Area {
  id        String     @id @default(uuid()) @db.Uuid
  name      AreaName
  reports   Report[]
  userAreas UserArea[]
}

model UserArea {
  userId String @db.Uuid
  areaId String @db.Uuid
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
}

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  authorId    String       @db.Uuid
  areaId      String       @db.Uuid
  content     String
  isoWeek     String
  status      ReportStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  title       String       @default("Laboratório Semanal")
  attachments Attachment[]
  comments    Comment[]
  likes       Like[]
  area        Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, areaId, isoWeek])
}

model Attachment {
  id        String         @id @default(uuid()) @db.Uuid
  reportId  String         @db.Uuid
  type      AttachmentType
  url       String
  filename  String
  sizeBytes Int
  report    Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Meeting {
  id         String       @id @default(uuid()) @db.Uuid
  date       DateTime
  title      String
  createdBy  String       @db.Uuid
  attendance Attendance[]
  creator    User         @relation("MeetingCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String  @id @default(uuid()) @db.Uuid
  meetingId String  @db.Uuid
  userId    String  @db.Uuid
  present   Boolean @default(false)
  notes     String?
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model Like {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reportId, userId])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  userId    String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  MEMBER
  MANAGER
  PROFESSOR
}

enum AreaName {
  CURSOS
  PROJETOS
  EVENTOS
  MARKETING
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum AttachmentType {
  VIDEO
  PDF
  IMAGE
}
